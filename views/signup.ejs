<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AssignTrust | Premium Signup</title>
    <link rel="stylesheet" href="/signup.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <main class="auth-container">
        <div class="auth-header">
            <h1>AssignTrust</h1>
            <p>Create your account to get started</p>
        </div>

        <form action="/signup" method="POST" id="mainSignupForm">

            <% if (errors && errors.length > 0) { %>
            <div class="error-box">
                <ul>
                    <% errors.forEach(err => { %>
                    <li>⚠ <%= err %></li>
                    <% }) %>
                </ul>
            </div>
            <% } %>
            
            <div class="input-group">
                <input type="text" value="<%= OldInput.name ? OldInput.name: '' %>" name="name" id="name" class="floating-input" placeholder="Full Name" required>
            </div>

            <div class="input-group">
                <input type="email" value="<%= OldInput.email ? OldInput.email: '' %>" name="email" id="email" class="floating-input" placeholder="Email Address" required>
            </div>

            <div class="input-group">
                <label class="select-label">College</label>
                <select name="college" value="<%= OldInput.college ? OldInput.college: '' %>" class="styled-select" required>
                    <option value="" disabled selected>Select Your College</option>
                    <option value="REC Rewa" <%= OldInput.college === 'REC Rewa' ? 'selected' : '' %>>Rewa Engineering College, Rewa</option>
                    <option value="IGEC Sagar" <%= OldInput.college === 'IGEC Sagar' ? 'selected' : '' %>>Indira Gandhi Engineering College, Sagar</option>
                </select>
            </div>

            <div class="input-group">
                <label class="select-label">Gender</label>
                <select name="gender" value="<%= OldInput.gender ? OldInput.gender: '' %>" class="styled-select" required>
                    <option value="" disabled selected>Select Your Gender</option>
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                    <option value="others">Others</option>
                </select>
            </div>

<div class="input-group">
    <label class="select-label">Role</label>
     <select name="role" value="<%= OldInput.role ? OldInput.role: '' %>" class="styled-select" required>
    <option value="" disabled selected>Select Your Role</option>
     <option value="client">Hire Writer</option>
    <option value="writer">Become Writer</option>
    </select>

</div>

            <div class="input-group">
                <input type="password" name="password" id="password" class="floating-input" placeholder="Password" required>
            </div>

            <div class="input-group">
                <input type="password" name="confirmPassword" id="confirmPassword" class="floating-input" placeholder="Confirm Password" required>
            </div>

            <div class="otp-section">
                <button type="button" class="btn btn-secondary" id="sendOtpBtn">
                    Send Verification OTP
                </button>

                <div class="input-group" style="margin-top: 1rem; margin-bottom: 1rem;">
                    <input type="text" id="otp" name="otp" class="floating-input" placeholder="Enter 6-digit OTP" style="text-align: center; letter-spacing: 2px;">
                </div>

                <button type="button" class="btn btn-secondary" id="verifyOtpBtn">
                    Verify OTP
                </button>

                <p id="otpStatus"></p>
            </div>

            <div class="forgot-wrapper">
                <a href="/forgot" class="forgot-link">Forgot Password?</a>
            </div>

            <button type="submit" class="btn btn-primary" id="signupBtn" disabled>
                Create Account
            </button>
        </form>

        <div class="auth-footer">
            Already have an account? <a href="/login">Login here</a>
        </div>
    </main>

<script>
    // Utility to show status
    const showStatus = (msg, isError = false) => {
        const statusEl = document.getElementById("otpStatus");
        statusEl.innerText = msg;
        statusEl.className = isError ? "status-error" : "status-success";
    };

    // --- SEND OTP ---
    document.getElementById("sendOtpBtn").addEventListener("click", async function() {
        const email = document.getElementById("email").value;
        const btn = this;

        if (!email) {
            showStatus("Please enter your email first ❌", true);
            return;
        }

        // Add Loading State
        btn.classList.add("loading");
        btn.disabled = true;
        showStatus("Sending OTP...", false);

        try {
            const response = await fetch("/otp", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email })
            });

            const data = await response.json();
            
            // Remove Loading State
            btn.classList.remove("loading");
            btn.disabled = false;

            if(data.success || response.ok) {
                showStatus("OTP Sent Successfully ✅", false);
            } else {
                showStatus(data.message || "Failed to send OTP", true);
            }

        } catch (err) {
            console.log(err);
            btn.classList.remove("loading");
            btn.disabled = false;
            showStatus("Unable To Send OTP ❌", true);
        }
    });

    // --- VERIFY OTP ---
    document.getElementById("verifyOtpBtn").addEventListener("click", async function() {
        const email = document.getElementById("email").value;
        const otp = document.getElementById("otp").value;
        const btn = this;

        if (!otp) {
            showStatus("Please enter OTP first ❌", true);
            return;
        }

        // Add Loading State
        btn.classList.add("loading");
        btn.disabled = true;
        showStatus("Verifying...", false);

        try {
            const response = await fetch("/verifyotp", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email, otp })
            });

            const data = await response.json();

            // Remove Loading State
            btn.classList.remove("loading");
            btn.disabled = false;

            if (data.success) {
                showStatus("OTP Verified ✅", false);
                document.getElementById("signupBtn").disabled = false;
                // Optional: Disable OTP inputs after success
                document.getElementById("otp").disabled = true;
                btn.disabled = true;
                document.getElementById("sendOtpBtn").disabled = true;
            } else {
                showStatus((data.message || "Invalid OTP") + " ❌", true);
            }

        } catch (err) {
            console.log(err);
            btn.classList.remove("loading");
            btn.disabled = false;
            showStatus("Verification Failed ❌", true);
        }
    });
</script>

</body>
</html>