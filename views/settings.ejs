<%- include('partials/header', { title: 'Settings | AssignTrust' }) %>
<%- include('partials/sidebar', { activePage: 'settings' }) %>

<main class="main-content">
    <%- include('partials/topbar') %>

    <div class="page-content">
        <div class="welcome-banner" style="padding: 20px 32px; margin-bottom: 20px;">
            <div class="welcome-text">
                <h2>Account Settings</h2>
                <p>Manage your account preferences and security.</p>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="main-column">
                <% if (error) { %>
                    <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                        <%= error %>
                    </div>
                <% } %>
                <% if (success) { %>
                    <div style="background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: var(--green); padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                        <%= success %>
                    </div>
                <% } %>

                <!-- Security Settings -->
                <div class="panel-card" style="margin-bottom: 20px;">
                    <h3 style="margin-bottom: 20px; font-size: 1.2rem;"><i class="fas fa-lock" style="color: var(--accent); margin-right: 10px;"></i> Change Password</h3>
                    <form action="/settings/change-password" method="POST">
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; margin-bottom: 5px; font-size: 0.9rem; color: var(--text-muted);">Current Password</label>
                            <input type="password" name="currentPassword" required style="width: 100%; padding: 10px; background: var(--bg-dark); border-radius: 8px; border: 1px solid var(--border); color: white;">
                        </div>
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; margin-bottom: 5px; font-size: 0.9rem; color: var(--text-muted);">New Password</label>
                            <input type="password" name="newPassword" required minlength="5" style="width: 100%; padding: 10px; background: var(--bg-dark); border-radius: 8px; border: 1px solid var(--border); color: white;">
                        </div>
                        <div style="margin-bottom: 20px;">
                            <label style="display: block; margin-bottom: 5px; font-size: 0.9rem; color: var(--text-muted);">Confirm New Password</label>
                            <input type="password" name="confirmNewPassword" required minlength="5" style="width: 100%; padding: 10px; background: var(--bg-dark); border-radius: 8px; border: 1px solid var(--border); color: white;">
                        </div>
                        <button type="submit" class="btn-primary">Update Password</button>
                    </form>
                </div>

            </div>
            
            <aside class="right-panel">
                <div class="panel-card">
                    <h3 style="margin-bottom: 15px; font-size: 1rem;"><i class="fas fa-info-circle" style="color: var(--blue); margin-right: 10px;"></i> Account Details</h3>
                    <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 10px;"><strong>Email:</strong> <%= user.email %></p>
                    <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 10px;"><strong>Role:</strong> <span style="text-transform: capitalize;"><%= user.role %></span></p>
                    <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 10px;"><strong>Joined:</strong> <%= new Date(user.createdAt).toLocaleDateString() %></p>
                </div>
            </aside>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
