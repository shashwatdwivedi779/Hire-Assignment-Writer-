<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AssignHub | Freelance Dashboard</title>
    <meta name="description"
        content="Professional assignment and freelance project dashboard for students and developers.">
    <link rel="stylesheet" href="/acpage.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
</head>

<body>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon"><i class="fas fa-bolt"></i></div>
            <span class="logo-text">AssignHub</span>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">MAIN</div>
            <a href="#" class="nav-item active" id="nav-dashboard">
                <i class="fas fa-chart-pie"></i>
                <span>Dashboard</span>
                <div class="nav-indicator"></div>
            </a>
            <a href="#" class="nav-item" id="nav-projects">
                <i class="fas fa-folder-open"></i>
                <span>My Projects</span>
                <span class="nav-badge">12</span>
            </a>
            <a href="/create" class="nav-item" id="nav-post">
                <i class="fas fa-plus-circle"></i>
                <span>Post Project</span>
            </a>
            <a href="#" class="nav-item" id="nav-gigs">
                <i class="fas fa-list-check"></i>
                <span>Gig Requests</span>
                <span class="nav-badge new">3</span>
            </a>

            <div class="nav-label">FINANCE</div>
            <a href="#" class="nav-item" id="nav-earn">
                <i class="fas fa-money-bill-trend-up"></i>
                <span>Earnings</span>
            </a>
            <a href="#" class="nav-item" id="nav-payments">
                <i class="fas fa-wallet"></i>
                <span>Payments</span>
            </a>

            <div class="nav-label">COMMUNICATION</div>
            <a href="#" class="nav-item" id="nav-messages">
                <i class="fas fa-message"></i>
                <span>Messages</span>
                <span class="nav-badge new">5</span>
            </a>
            <a href="#" class="nav-item" id="nav-notifs">
                <i class="fas fa-bell"></i>
                <span>Notifications</span>
            </a>

            <div class="nav-label">ACCOUNT</div>
            <a href="#" class="nav-item" id="nav-profile">
                <i class="fas fa-user-circle"></i>
                <span>My Profile</span>
            </a>
            <a href="#" class="nav-item" id="nav-settings">
                <i class="fas fa-gear"></i>
                <span>Settings</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <img src="https://i.pravatar.cc/150?img=12" alt="Profile Photo" class="sidebar-avatar">
            <div class="sidebar-user-info">
                <p class="sidebar-username">Shashwat</p>
                <p class="sidebar-role">Pro Seller ⭐</p>
            </div>
            <a href="#" class="sidebar-logout" title="Logout"><i class="fas fa-right-from-bracket"></i></a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main-content">

        <!-- TOP NAVBAR -->
        <header class="topbar">
            <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
            <div class="topbar-search">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" placeholder="Search projects, gigs, students...">
            </div>
            <div class="topbar-right">
                <button class="icon-btn" id="notifBtn" title="Notifications">
                    <i class="fas fa-bell"></i>
                    <span class="dot-badge"></span>
                </button>
                <button class="icon-btn" id="msgBtn" title="Messages">
                    <i class="fas fa-envelope"></i>
                    <span class="dot-badge"></span>
                </button>
                <div class="topbar-profile">
                    <img src="https://i.pravatar.cc/150?img=12" alt="Profile">
                    <div class="topbar-profile-info">
                        <span class="topbar-name">Shashwat</span>
                        <span class="topbar-college">REC Rewa | CSE</span>
                    </div>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <div class="page-content">

            <!-- WELCOME BANNER -->
            <div class="welcome-banner">
                <div class="welcome-text">
                    <h1>Good Morning, Shashwat! 👋</h1>
                    <p>Here's what's happening with your projects today.</p>
                </div>
                <a href="/create" class="btn-primary" id="postProjectBtn">
                    <i class="fas fa-plus"></i> Post New Project
                </a>
            </div>

            <!-- STATS GRID -->
            <section class="stats-grid" aria-label="Dashboard Statistics">

                <div class="stat-card" id="statTotalProjects">
                    <div class="stat-icon purple">
                        <i class="fas fa-briefcase"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value" data-target="45">0</span>
                        <span class="stat-label">Total Projects</span>
                    </div>
                    <div class="stat-trend up"><i class="fas fa-arrow-trend-up"></i> 12%</div>
                </div>

                <div class="stat-card" id="statActiveProjects">
                    <div class="stat-icon blue">
                        <i class="fas fa-spinner"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value" data-target="12">0</span>
                        <span class="stat-label">Active Projects</span>
                    </div>
                    <div class="stat-trend up"><i class="fas fa-arrow-trend-up"></i> 5%</div>
                </div>

                <div class="stat-card" id="statCompleted">
                    <div class="stat-icon green">
                        <i class="fas fa-circle-check"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value" data-target="28">0</span>
                        <span class="stat-label">Completed</span>
                    </div>
                    <div class="stat-trend up"><i class="fas fa-arrow-trend-up"></i> 8%</div>
                </div>

                <div class="stat-card" id="statEarnings">
                    <div class="stat-icon orange">
                        <i class="fas fa-indian-rupee-sign"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value rupee">₹12,500</span>
                        <span class="stat-label">Total Earnings</span>
                    </div>
                    <div class="stat-trend up"><i class="fas fa-arrow-trend-up"></i> 18%</div>
                </div>

                <div class="stat-card" id="statRating">
                    <div class="stat-icon yellow">
                        <i class="fas fa-star"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">4.9</span>
                        <span class="stat-label">Avg. Rating</span>
                    </div>
                    <div class="stat-trend up"><i class="fas fa-arrow-trend-up"></i> 2%</div>
                </div>

                <div class="stat-card" id="statReviews">
                    <div class="stat-icon pink">
                        <i class="fas fa-star-half-stroke"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value" data-target="5">0</span>
                        <span class="stat-label">Pending Reviews</span>
                    </div>
                    <div class="stat-trend down"><i class="fas fa-arrow-trend-down"></i> 3%</div>
                </div>

            </section>

            <!-- LOWER GRID: Projects + Sidebar Panel -->
            <div class="dashboard-grid">

                <!-- RECENT PROJECTS TABLE -->
                <section class="projects-section" aria-label="Recent Projects">
                    <div class="section-header">
                        <h2>Recent Projects</h2>
                        <a href="#" class="view-all-link">View All <i class="fas fa-arrow-right"></i></a>
                    </div>

                    <div class="project-list">

                        <div class="project-card" id="proj1">
                            <div class="proj-thumb purple-bg">
                                <i class="fas fa-code"></i>
                            </div>
                            <div class="proj-info">
                                <h3>Full-Stack Web App</h3>
                                <p>Node.js + MongoDB + EJS</p>
                            </div>
                            <div class="proj-meta">
                                <span class="proj-price">₹3,500</span>
                                <span class="proj-status active-status">Active</span>
                            </div>
                            <div class="proj-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width:75%"></div>
                                </div>
                                <span>75%</span>
                            </div>
                        </div>

                        <div class="project-card" id="proj2">
                            <div class="proj-thumb blue-bg">
                                <i class="fas fa-mobile-screen"></i>
                            </div>
                            <div class="proj-info">
                                <h3>React Native App</h3>
                                <p>Cross-platform mobile app</p>
                            </div>
                            <div class="proj-meta">
                                <span class="proj-price">₹5,000</span>
                                <span class="proj-status active-status">Active</span>
                            </div>
                            <div class="proj-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width:40%"></div>
                                </div>
                                <span>40%</span>
                            </div>
                        </div>

                        <div class="project-card" id="proj3">
                            <div class="proj-thumb green-bg">
                                <i class="fas fa-database"></i>
                            </div>
                            <div class="proj-info">
                                <h3>DBMS Assignment</h3>
                                <p>SQL schema design & ER diagram</p>
                            </div>
                            <div class="proj-meta">
                                <span class="proj-price">₹1,200</span>
                                <span class="proj-status done-status">Completed</span>
                            </div>
                            <div class="proj-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill done" style="width:100%"></div>
                                </div>
                                <span>100%</span>
                            </div>
                        </div>

                        <div class="project-card" id="proj4">
                            <div class="proj-thumb orange-bg">
                                <i class="fas fa-robot"></i>
                            </div>
                            <div class="proj-info">
                                <h3>ML Model Training</h3>
                                <p>Python + TensorFlow classifier</p>
                            </div>
                            <div class="proj-meta">
                                <span class="proj-price">₹4,200</span>
                                <span class="proj-status pending-status">Pending</span>
                            </div>
                            <div class="proj-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill pending" style="width:10%"></div>
                                </div>
                                <span>10%</span>
                            </div>
                        </div>

                    </div>
                </section>

                <!-- RIGHT PANEL -->
                <aside class="right-panel">

                    <!-- QUICK ACTIONS -->
                    <div class="panel-card" id="quickActions">
                        <h3>Quick Actions</h3>
                        <div class="quick-action-grid">
                            <a href="/create" class="qa-btn" id="qaUpload">
                                <i class="fas fa-upload"></i>
                                <span>Upload Project</span>
                            </a>
                            <a href="#" class="qa-btn" id="qaGigs">
                                <i class="fas fa-list-check"></i>
                                <span>View Gigs</span>
                            </a>
                            <a href="#" class="qa-btn" id="qaMessages">
                                <i class="fas fa-comments"></i>
                                <span>Messages</span>
                            </a>
                            <a href="#" class="qa-btn" id="qaEarnings">
                                <i class="fas fa-money-bill-trend-up"></i>
                                <span>Earnings</span>
                            </a>
                        </div>
                    </div>

                    <!-- ACTIVITY FEED -->
                    <div class="panel-card" id="activityFeed">
                        <div class="panel-header">
                            <h3>Recent Activity</h3>
                            <a href="#" class="view-all-link small">See all</a>
                        </div>
                        <div class="activity-list">

                            <div class="activity-item" id="act1">
                                <div class="activity-icon green-icon">
                                    <i class="fas fa-circle-check"></i>
                                </div>
                                <div class="activity-content">
                                    <p class="activity-title">Web Dev Assignment Delivered</p>
                                    <p class="activity-time">2 hours ago</p>
                                </div>
                            </div>

                            <div class="activity-item" id="act2">
                                <div class="activity-icon blue-icon">
                                    <i class="fas fa-message"></i>
                                </div>
                                <div class="activity-content">
                                    <p class="activity-title">New message from Rahul</p>
                                    <p class="activity-time">4 hours ago</p>
                                </div>
                            </div>

                            <div class="activity-item" id="act3">
                                <div class="activity-icon orange-icon">
                                    <i class="fas fa-wallet"></i>
                                </div>
                                <div class="activity-content">
                                    <p class="activity-title">₹1,500 credited to wallet</p>
                                    <p class="activity-time">Yesterday</p>
                                </div>
                            </div>

                            <div class="activity-item" id="act4">
                                <div class="activity-icon yellow-icon">
                                    <i class="fas fa-star"></i>
                                </div>
                                <div class="activity-content">
                                    <p class="activity-title">5★ review from Priya</p>
                                    <p class="activity-time">2 days ago</p>
                                </div>
                            </div>

                            <div class="activity-item" id="act5">
                                <div class="activity-icon purple-icon">
                                    <i class="fas fa-file-circle-plus"></i>
                                </div>
                                <div class="activity-content">
                                    <p class="activity-title">New gig request received</p>
                                    <p class="activity-time">3 days ago</p>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- PROFILE COMPLETION -->
                    <div class="panel-card" id="profileCompletion">
                        <h3>Profile Strength</h3>
                        <div class="profile-strength-bar">
                            <div class="ps-fill" style="width:82%"></div>
                        </div>
                        <p class="ps-label">82% Complete — <a href="#" class="ps-link">Complete Profile</a></p>
                        <ul class="ps-checklist">
                            <li class="done-item"><i class="fas fa-check-circle"></i> Add Profile Photo</li>
                            <li class="done-item"><i class="fas fa-check-circle"></i> Bio & Skills</li>
                            <li class="done-item"><i class="fas fa-check-circle"></i> Portfolio Projects</li>
                            <li class="pending-item"><i class="fas fa-circle"></i> Bank / UPI Details</li>
                            <li class="pending-item"><i class="fas fa-circle"></i> Verified ID</li>
                        </ul>
                    </div>

                </aside>

            </div><!-- end dashboard-grid -->

        </div><!-- end page-content -->

    </main>

    <!-- OVERLAY for mobile -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <script>
        // Sidebar toggle
        const menuToggle = document.getElementById('menuToggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        menuToggle.addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('active');
        });
        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('active');
        });

        // Nav active state
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', function (e) {
                document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
                this.classList.add('active');
            });
        });

        // Count-up animation
        document.querySelectorAll('.stat-value[data-target]').forEach(el => {
            const target = parseInt(el.dataset.target);
            let current = 0;
            const step = Math.ceil(target / 40);
            const interval = setInterval(() => {
                current = Math.min(current + step, target);
                el.textContent = current;
                if (current >= target) clearInterval(interval);
            }, 30);
        });
    </script>

</body>

</html>