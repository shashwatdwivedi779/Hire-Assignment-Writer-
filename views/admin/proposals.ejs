<%- include('../partials/header', { title: 'Manage Proposals | AssignTrust Admin' }) %>
<%- include('../partials/sidebar', { activePage: 'proposals' }) %>

<main class="main-content">
    <%- include('../partials/topbar') %>

    <div class="page-content">
        <div class="welcome-banner" style="background: linear-gradient(135deg, #1e1b4b, #312e81); padding: 20px 32px; margin-bottom: 20px;">
            <div class="welcome-text">
                <h2>Manage Proposals</h2>
                <p>All proposals submitted across the platform.</p>
            </div>
            <span style="background: rgba(255,255,255,0.1); padding: 8px 18px; border-radius: 8px; font-size: 0.9rem;">
                Total: <strong><%= proposals.length %></strong>
            </span>
        </div>

        <div class="panel-card">
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border); color: var(--text-muted); text-align: left;">
                            <th style="padding: 12px 16px;">#</th>
                            <th style="padding: 12px 16px;">Writer</th>
                            <th style="padding: 12px 16px;">College</th>
                            <th style="padding: 12px 16px;">Assignment</th>
                            <th style="padding: 12px 16px;">Bid (₹)</th>
                            <th style="padding: 12px 16px;">Delivery</th>
                            <th style="padding: 12px 16px;">Status</th>
                            <th style="padding: 12px 16px;">Submitted</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (proposals && proposals.length > 0) { %>
                            <% proposals.forEach((prop, i) => { %>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.15s;"
                                onmouseover="this.style.background='rgba(255,255,255,0.03)'"
                                onmouseout="this.style.background=''">
                                <td style="padding: 12px 16px; color: var(--text-muted);"><%= i + 1 %></td>
                                <td style="padding: 12px 16px;">
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <img src="<%= prop.writer.avatar || 'https://i.pravatar.cc/40?img=' + (i+1) %>"
                                             style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;">
                                        <span><%= prop.writer.name %></span>
                                    </div>
                                </td>
                                <td style="padding: 12px 16px; color: var(--text-muted); font-size: 0.82rem;">
                                    <%= prop.writer.college %>
                                </td>
                                <td style="padding: 12px 16px; max-width: 200px;">
                                    <% if (prop.assignment) { %>
                                        <a href="/assignment/<%= prop.assignment._id %>"
                                           style="color: var(--accent); text-decoration: none; font-weight: 500;">
                                            <%= prop.assignment.title.substring(0, 50) %><%= prop.assignment.title.length > 50 ? '...' : '' %>
                                        </a>
                                        <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 2px;">
                                            Status: <span style="text-transform: capitalize;"><%= prop.assignment.status %></span>
                                        </div>
                                    <% } else { %>
                                        <span style="color: var(--text-muted);">Assignment deleted</span>
                                    <% } %>
                                </td>
                                <td style="padding: 12px 16px; font-weight: 600; color: #10b981;">
                                    ₹<%= prop.bidAmount.toLocaleString() %>
                                </td>
                                <td style="padding: 12px 16px; color: var(--text-muted);">
                                    <%= prop.deliveryTime %>h
                                </td>
                                <td style="padding: 12px 16px;">
                                    <% const sc = prop.status === 'accepted' ? '#10b981' : prop.status === 'rejected' ? '#ef4444' : prop.status === 'withdrawn' ? '#f59e0b' : '#6c63ff'; %>
                                    <span style="padding: 4px 12px; background: <%= sc %>22; color: <%= sc %>; border-radius: 20px; font-size: 0.8rem; font-weight: 600; text-transform: capitalize;">
                                        <%= prop.status %>
                                    </span>
                                </td>
                                <td style="padding: 12px 16px; color: var(--text-muted); font-size: 0.82rem;">
                                    <%= new Date(prop.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" style="padding: 40px; text-align: center; color: var(--text-muted);">
                                    <i class="fas fa-inbox" style="font-size: 2rem; margin-bottom: 10px; display: block; opacity: 0.4;"></i>
                                    No proposals found.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
