<%- include('../partials/header', { title: 'Client Dashboard | AssignTrust' }) %>
<%- include('../partials/sidebar', { activePage: 'dashboard' }) %>

<main class="main-content">
    <%- include('../partials/topbar') %>

    <div class="page-content">
        <!-- WELCOME BANNER -->
        <div class="welcome-banner">
            <div class="welcome-text">
                <h1>Welcome back, <%= user.name %>! 👋</h1>
                <p>Manage your assignments and review incoming proposals.</p>
            </div>
            <a href="/create" class="btn-primary">
                <i class="fas fa-plus"></i> Post New Project
            </a>
        </div>

        <!-- STATS GRID -->
        <section class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon purple"><i class="fas fa-briefcase"></i></div>
                <div class="stat-info">
                    <span class="stat-value"><%= stats.totalProjects %></span>
                    <span class="stat-label">Total Projects</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue"><i class="fas fa-spinner"></i></div>
                <div class="stat-info">
                    <span class="stat-value"><%= stats.activeProjects %></span>
                    <span class="stat-label">Active Projects</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon yellow"><i class="fas fa-clock"></i></div>
                <div class="stat-info">
                    <span class="stat-value"><%= stats.pendingProjects %></span>
                    <span class="stat-label">Pending Projects</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
                <div class="stat-info">
                    <span class="stat-value"><%= stats.completedProjects %></span>
                    <span class="stat-label">Completed</span>
                </div>
            </div>
        </section>

        <div class="dashboard-grid">
            <!-- RECENT PROJECTS TABLE -->
            <section class="projects-section">
                <div class="section-header">
                    <h2>Recent Assignments</h2>
                    <a href="/my-assignments" class="view-all-link">View All <i class="fas fa-arrow-right"></i></a>
                </div>

                <div class="project-list">
                    <% if (recentAssignments && recentAssignments.length > 0) { %>
                        <% recentAssignments.forEach(project => { %>
                            <div class="project-card">
                                <div class="proj-thumb purple-bg"><i class="fas fa-file-alt"></i></div>
                                <div class="proj-info">
                                    <h3><%= project.title %></h3>
                                    <p><%= project.subject %></p>
                                </div>
                                <div class="proj-meta">
                                    <span class="proj-price">₹<%= project.budget.min %> - ₹<%= project.budget.max %></span>
                                    <% 
                                    let statusClass = 'pending-status';
                                    let statusText = project.status;
                                    if (['assigned', 'in_progress'].includes(project.status)) statusClass = 'active-status';
                                    if (project.status === 'completed') statusClass = 'done-status';
                                    %>
                                    <span class="proj-status <%= statusClass %>"><%= statusText %></span>
                                </div>
                                <div class="proj-progress" style="display:flex; justify-content:flex-end;">
                                    <a href="/assignment/<%= project._id %>" class="btn-primary" style="padding: 6px 12px; font-size: 0.8rem;">View</a>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p style="color: var(--text-muted); text-align: center; padding: 20px;">You haven't posted any assignments yet.</p>
                    <% } %>
                </div>
            </section>

            <!-- RIGHT PANEL -->
            <aside class="right-panel">
                <!-- ACTIVITY FEED -->
                <div class="panel-card">
                    <div class="panel-header">
                        <h3>Recent Activity</h3>
                        <a href="/notifications" class="view-all-link small">See all</a>
                    </div>
                    <div class="activity-list">
                        <% if (notifications && notifications.length > 0) { %>
                            <% notifications.forEach(notif => { %>
                                <div class="activity-item" onclick="window.location.href='<%= notif.link %>'" style="cursor: pointer;">
                                    <div class="activity-icon blue-icon"><i class="fas fa-bell"></i></div>
                                    <div class="activity-content">
                                        <p class="activity-title"><%= notif.message %></p>
                                        <p class="activity-time"><%= new Date(notif.createdAt).toLocaleDateString() %></p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p style="color: var(--text-muted); font-size: 0.85rem;">No recent activity.</p>
                        <% } %>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
