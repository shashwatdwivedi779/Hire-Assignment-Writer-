<%- include('../partials/header', { title: 'Proposals | AssignTrust' }) %>
<%- include('../partials/sidebar', { activePage: 'projects' }) %>

<main class="main-content">
    <%- include('../partials/topbar') %>

    <div class="page-content">
        <a href="/assignment/<%= assignment._id %>" style="display: inline-block; margin-bottom: 20px; color: var(--text-muted); font-size: 0.9rem;"><i class="fas fa-arrow-left"></i> Back to Assignment</a>
        
        <div class="welcome-banner" style="padding: 20px 32px; margin-bottom: 20px;">
            <div class="welcome-text">
                <h2 style="font-size: 1.5rem;">Proposals for "<%= assignment.title %>"</h2>
                <p>Review the proposals below and hire the best writer for your project.</p>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="main-column">
                <% if (proposals && proposals.length > 0) { %>
                    <% proposals.forEach(prop => { %>
                        <div class="panel-card" style="margin-bottom: 20px; <%= prop.status === 'accepted' ? 'border-color: var(--green);' : (prop.status === 'rejected' ? 'opacity: 0.7;' : '') %>">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                                <div style="display: flex; gap: 15px;">
                                    <img src="<%= prop.writer.avatar || 'https://i.pravatar.cc/150?img=12' %>" alt="Writer" style="width: 50px; height: 50px; border-radius: 50%;">
                                    <div>
                                        <h3 style="font-size: 1.1rem; margin-bottom: 3px;">
                                            <a href="/profile/<%= prop.writer._id %>" style="color: white; text-decoration: none;"><%= prop.writer.name %></a>
                                        </h3>
                                        <p style="font-size: 0.85rem; color: var(--text-muted);"><%= prop.writer.college %> • <%= prop.writer.skills.slice(0,3).join(', ') %></p>
                                    </div>
                                </div>
                                <div style="text-align: right;">
                                    <div style="font-size: 1.2rem; font-weight: 800; color: var(--green);">₹<%= prop.bidAmount %></div>
                                    <p style="font-size: 0.85rem; color: var(--text-muted);">in <%= prop.deliveryTime %> hours</p>
                                </div>
                            </div>
                            
                            <div style="margin-bottom: 20px; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px;">
                                <p style="font-size: 0.95rem; line-height: 1.6; color: var(--text-muted); white-space: pre-wrap;"><%= prop.coverLetter %></p>
                            </div>
                            
                            <% if (prop.status === 'pending') { %>
                                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                                    <button onclick="rejectProposal('<%= prop._id %>')" class="btn-primary" style="background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.3);">Reject</button>
                                    <button onclick="startChat('<%= prop.writer._id %>', '<%= assignment._id %>')" class="btn-primary" style="background: var(--bg-card2); border: 1px solid var(--border); color: white;"><i class="fas fa-comment"></i> Chat</button>
                                    <button onclick="acceptProposal('<%= prop._id %>')" class="btn-primary" style="background: var(--green);"><i class="fas fa-handshake"></i> Accept & Hire</button>
                                </div>
                            <% } else { %>
                                <div style="display: flex; justify-content: flex-end;">
                                    <span class="proj-status" style="text-transform: capitalize; padding: 6px 12px; border-radius: 6px; <%= prop.status === 'accepted' ? 'background: rgba(34,197,94,0.15); color: var(--green);' : 'background: rgba(239,68,68,0.15); color: var(--red);' %>">
                                        <i class="fas <%= prop.status === 'accepted' ? 'fa-check-circle' : 'fa-times-circle' %>"></i> <%= prop.status %>
                                    </span>
                                </div>
                            <% } %>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="panel-card" style="text-align: center; padding: 50px;">
                        <i class="fas fa-inbox" style="font-size: 3rem; color: var(--border); margin-bottom: 20px;"></i>
                        <h3>No proposals yet</h3>
                        <p style="color: var(--text-muted);">Writers have not submitted any proposals for this assignment yet. Wait for a bit or try sharing it.</p>
                    </div>
                <% } %>
            </div>
            
            <aside class="right-panel">
                <div class="panel-card">
                    <h3 style="font-size: 0.95rem; margin-bottom: 15px;">Budget Guide</h3>
                    <div style="font-size: 1.5rem; font-weight: 800; color: var(--accent); margin-bottom: 5px;">₹<%= assignment.budget.min %> - ₹<%= assignment.budget.max %></div>
                    <p style="font-size: 0.85rem; color: var(--text-muted);">Your original estimated budget.</p>
                    <hr style="border-color: var(--border); margin: 15px 0;">
                    <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5;">Remember, you don't have to choose the lowest bid. Quality, communication, and delivery time are also important factors when hiring a writer.</p>
                </div>
            </aside>
        </div>
    </div>
</main>

<script>
async function startChat(recipientId, assignmentId) {
    try {
        const res = await fetch('/chat/start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ recipientId, assignmentId })
        });
        const data = await res.json();
        if (data.success) {
            window.location.href = `/chat/${data.conversationId}`;
        } else {
            alert(data.message);
        }
    } catch (err) {
        alert('Error starting chat');
    }
}

async function acceptProposal(proposalId) {
    if (!confirm('Are you sure you want to hire this writer? This will reject all other proposals.')) return;
    try {
        const res = await fetch(`/proposal/${proposalId}/accept`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            alert('Writer hired successfully!');
            window.location.reload();
        } else {
            alert(data.message);
        }
    } catch (err) {
        alert('Error accepting proposal');
    }
}

async function rejectProposal(proposalId) {
    if (!confirm('Are you sure you want to reject this proposal?')) return;
    try {
        const res = await fetch(`/proposal/${proposalId}/reject`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.message);
        }
    } catch (err) {
        alert('Error rejecting proposal');
    }
}
</script>

<%- include('../partials/footer') %>
