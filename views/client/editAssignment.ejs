<%- include('../partials/header', { title: 'Edit Assignment | AssignTrust' }) %>
<%- include('../partials/sidebar', { activePage: 'projects' }) %>

<main class="main-content">
    <%- include('../partials/topbar') %>

    <div class="page-content">
        <a href="/assignment/<%= assignment._id %>" style="display: inline-block; margin-bottom: 20px; color: var(--text-muted); font-size: 0.9rem;"><i class="fas fa-arrow-left"></i> Back to Assignment</a>
        
        <div class="welcome-banner" style="padding: 20px 32px; margin-bottom: 20px;">
            <div class="welcome-text">
                <h2>Edit Details</h2>
                <p>Update the core details of your assignment.</p>
            </div>
        </div>

        <div class="panel-card" style="max-width: 800px; margin: 0 auto;">
            <form id="editForm">
                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 0.9rem;">Title</label>
                    <input type="text" id="title" value="<%= assignment.title %>" required style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-dark); border: 1px solid var(--border); color: white;">
                </div>
                
                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 0.9rem;">Description</label>
                    <textarea id="description" rows="6" required style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-dark); border: 1px solid var(--border); color: white;"><%= assignment.description %></textarea>
                </div>

                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 0.9rem;">Required Skills (comma separated)</label>
                    <input type="text" id="requiredSkills" value="<%= assignment.requiredSkills ? assignment.requiredSkills.join(', ') : '' %>" style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-dark); border: 1px solid var(--border); color: white;">
                </div>

                <div style="margin-bottom: 25px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 0.9rem;">Deadline</label>
                    <input type="date" id="deadline" value="<%= new Date(assignment.deadline).toISOString().split('T')[0] %>" required style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-dark); border: 1px solid var(--border); color: white; color-scheme: dark;">
                </div>

                <button type="submit" class="btn-primary" style="width: 100%; justify-content: center;" id="submitBtn">Save Changes</button>
            </form>
        </div>
    </div>
</main>

<script>
document.getElementById('editForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerText = 'Saving...';
    
    try {
        const title = document.getElementById('title').value;
        const description = document.getElementById('description').value;
        const requiredSkills = document.getElementById('requiredSkills').value;
        const deadline = document.getElementById('deadline').value;

        const res = await fetch('/assignment/<%= assignment._id %>/edit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title, description, requiredSkills, deadline })
        });
        const data = await res.json();
        
        if (data.success) {
            window.location.href = '/assignment/<%= assignment._id %>';
        } else {
            alert(data.message);
            btn.disabled = false;
            btn.innerText = 'Save Changes';
        }
    } catch(err) {
        alert('Error saving changes');
        btn.disabled = false;
        btn.innerText = 'Save Changes';
    }
});
</script>

<%- include('../partials/footer') %>
