<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AssignTrust | Verified Assignment Writers</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="navbar">
        <div class="container nav-container">
            <div class="logo">Assign<span>Trust</span></div>
            <div class="nav-links">
                <a href="#how-it-works">How it Works</a>
                <a href="#features">Features</a>
                <a href="#escrow">Escrow System</a>
            </div>

            <% if(!isLoggedIn){ %>
                <a href="/login" class="nav-signin">Sign In</a>
            <% } else { %>
                <a href="/dashboard" class="nav-signin">Dashboard</a>
            <% } %>
        </div>
    </nav>

    <section class="hero relative-section">
        <div class="container hero-grid">
            
            <div class="hero-content animate-on-scroll">
                <h1>Get Your Assignments Done by <span>Verified Writers</span></h1>
                <p>Connect with skilled assignment writers and get high-quality work on time.</p>
                
                <% if(!isLoggedIn){ %>
                    <div class="hero-buttons">
                        <a href="/signup" class="btn btn-primary">Post Assignment</a>
                        <a href="/signup" class="btn btn-outline">Become a Writer</a>
                    </div>
                <% } else { %>
                    <div class="hero-welcome">
                        <h3>Welcome back, <span><%= user.name %></span>!</h3>
                        <div class="hero-buttons">
                            <% if( user.role === 'client' ){ %>
                                <a href="/dashboard" class="btn btn-primary">Post Assignment & Hire Writer</a>
                            <% } else if( user.role === 'writer'){ %>
                                <a href="/dashboard" class="btn btn-primary">Complete Assignment & Earn</a>
                            <% } else { %>
                                <a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>

            <div class="hero-visual animate-on-scroll delay-1">
                <img src="PicB.jpg" alt="Student writing" class="hero-image">
            </div>

        </div>
    </section>

    <div class="marquee-container">
        <div class="marquee-content">
            <span class="marquee-item">✅ Trust & Guaranteed Delivery</span>
            <span class="marquee-item">✍️ Skilled Quality Writers</span>
            <span class="marquee-item">✅ Trust & Guaranteed Delivery</span>
            <span class="marquee-item">✍️ Skilled Quality Writers</span>
            <span class="marquee-item">✅ Trust & Guaranteed Delivery</span>
            <span class="marquee-item">✍️ Skilled Quality Writers</span>
            <span class="marquee-item">✅ Trust & Guaranteed Delivery</span>
            <span class="marquee-item">✍️ Skilled Quality Writers</span>
            <span class="marquee-item">✅ Trust & Guaranteed Delivery</span>
        </div>
    </div>

    <section id="how-it-works" class="section bg-light">
        <div class="container">
            <h2 class="text-center animate-on-scroll">How It Works</h2>
            <div class="how-it-works-grid">
                
                <div class="card student-card animate-on-scroll">
                    <h3>For Students</h3>
                    <ul>
                        <li><span class="step-num">1</span> Upload Assignment Requirements</li>
                        <li><span class="step-num">2</span> Receive Bids from Writers</li>
                        <li><span class="step-num">3</span> Choose the Best Writer</li>
                        <li><span class="step-num">4</span> Chat and Monitor Progress</li>
                        <li><span class="step-num">5</span> Receive Assignment</li>
                        <li><span class="step-num">6</span> Approve & Review Writer</li>
                    </ul>
                </div>

                <div class="center-image-wrapper animate-on-scroll delay-1">
                    <img src="PicA.jpg" alt="Person writing outdoors" class="feature-image">
                </div>

                <div class="card writer-card animate-on-scroll delay-2">
                    <h3>For Writers</h3>
                    <ul>
                        <li><span class="step-num">1</span> Create Profile</li>
                        <li><span class="step-num">2</span> Browse Available Assignments</li>
                        <li><span class="step-num">3</span> Submit Proposal</li>
                        <li><span class="step-num">4</span> Get Hired</li>
                        <li><span class="step-num">5</span> Complete Work</li>
                        <li><span class="step-num">6</span> Receive Review</li>
                    </ul>
                </div>

            </div>
        </div>
    </section>

    <section class="section bg-white">
        <div class="container">
            <h2 class="text-center animate-on-scroll">Why Choose Us</h2>
            <div class="grid-3 animate-on-scroll delay-1">
                <div class="card">
                    <h4>💬 Direct Communication</h4>
                    <p>Chat directly with your writer to ensure perfect understanding.</p>
                </div>
                <div class="card">
                    <h4>⭐ Verified Writers</h4>
                    <p>Work with skilled and trusted assignment writers.</p>
                </div>
                <div class="card">
                    <h4>⏱️ On-Time Delivery</h4>
                    <p>Receive assignments strictly before deadlines.</p>
                </div>
                <div class="card">
                    <h4>✅ Quality Assurance</h4>
                    <p>Assignments are reviewed for completeness and quality.</p>
                </div>
                <div class="card">
                    <h4>💰 Fair Pricing</h4>
                    <p>Choose writers based on your budget constraints.</p>
                </div>
                <div class="card">
                    <h4>🎧 24/7 Support</h4>
                    <p>Get immediate assistance whenever needed.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="features" class="section bg-dark text-white">
        <div class="container">
            <h2 class="text-center animate-on-scroll" style="color:beige">Platform Features</h2>
            <div class="grid-3 animate-on-scroll delay-1">
                <div class="dark-card">
                    <h3 class="text-indigo">👨‍🎓 Student Side</h3>
                    <p><strong>Assignment Posting:</strong> Subject, Topic, Word Count, Deadline, Budget, File Upload.</p>
                    <p><strong>Writer Selection:</strong> View profiles, ratings, and reviews.</p>
                    <p><strong>Order Tracking:</strong> Live status tracking.</p>
                    <p><strong>Chat System:</strong> Direct communication.</p>
                </div>
                <div class="dark-card">
                    <h3 class="text-green">✍️ Writer Side</h3>
                    <p><strong>Dashboard:</strong> Available Assignments, Earnings, Active Projects.</p>
                    <p><strong>Proposal System:</strong> Set Price, Delivery Time, and Message.</p>
                    <p><strong>Wallet:</strong> Track Earnings, Withdrawals, Pending Payments.</p>
                </div>
                <div class="dark-card">
                    <h3 class="text-red">🛡️ Admin Panel</h3>
                    <p><strong>User Management:</strong> Control Students & Writers.</p>
                    <p><strong>Dispute Resolution:</strong> Handle conflicts fairly.</p>
                    <p><strong>Assignment Verification:</strong> Check submissions.</p>
                    <p><strong>Payment Monitoring:</strong> Prevent fraud.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="escrow" class="section bg-white text-center">
        <div class="container animate-on-scroll">
            <h2>Secure Escrow Payment System</h2>
            <p>Your money is safely held in escrow and only released to the writer when you are completely satisfied with the project.</p>
            <div class="escrow-workflow">
                <div class="workflow-step">
                    💳
                    <span>1. Deposit Funds</span>
                </div>
                <div class="workflow-arrow">➔</div>
                <div class="workflow-step">
                    🔒
                    <span>2. Safely Escrowed</span>
                </div>
                <div class="workflow-arrow">➔</div>
                <div class="workflow-step">
                    ✍️
                    <span>3. Assignment Written</span>
                </div>
                <div class="workflow-arrow">➔</div>
                <div class="workflow-step">
                    ✅
                    <span>4. Funds Released</span>
                </div>
            </div>
        </div>
    </section>

    <section class="section bg-indigo text-white text-center">
        <div class="container grid-4 animate-on-scroll">
            <div>
                <h2 class="stat-number">10,000+</h2>
                <p class="as">Assignments Completed</p>
            </div>
            <div>
                <h2 class="stat-number">2,000+</h2>
                <p class="as">Active Writers</p>
            </div>
            <div>
                <h2 class="stat-number">95%</h2>
                <p class="as">Client Satisfaction</p>
            </div>
            <div>
                <h2 class="stat-number">24 Hrs</h2>
                <p class="as">Average Response Time</p>
            </div>
        </div>
    </section>

    <footer>
        <div class="container text-center">
            <p>&copy; 2026 AssignTrust. All rights reserved.</p>
        </div>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.15
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        observer.unobserve(entry.target); 
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.animate-on-scroll').forEach(element => {
                observer.observe(element);
            });
        });
    </script>
</body>
</html>