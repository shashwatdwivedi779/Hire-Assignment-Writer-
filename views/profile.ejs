<%- include('partials/header', { title: profile.name + ' | Profile' }) %>
<%- include('partials/sidebar', { activePage: 'profile' }) %>

<main class="main-content">
    <%- include('partials/topbar') %>

    <div class="page-content">
        <div class="dashboard-grid">
            <div class="main-column">
                <div class="panel-card" style="text-align: center; padding: 40px 20px;">
                    <img src="<%= profile.avatar || 'https://i.pravatar.cc/150?img=12' %>" alt="Profile" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin-bottom: 15px; border: 4px solid var(--bg-dark);">
                    <h2 style="font-size: 1.8rem; margin-bottom: 5px;"><%= profile.name %></h2>
                    <p style="color: var(--accent); font-weight: 600; text-transform: capitalize; margin-bottom: 15px;"><%= profile.role %></p>
                    
                    <div style="display: flex; gap: 15px; justify-content: center; margin-bottom: 25px;">
                        <span style="background: rgba(255,255,255,0.05); padding: 6px 12px; border-radius: 8px; font-size: 0.85rem;"><i class="fas fa-university"></i> <%= profile.college %></span>
                        <span style="background: rgba(255,255,255,0.05); padding: 6px 12px; border-radius: 8px; font-size: 0.85rem;"><i class="fas fa-check-circle"></i> <%= completedCount %> Completed</span>
                    </div>

                    <p style="color: var(--text-muted); line-height: 1.6; max-width: 600px; margin: 0 auto 30px;"><%= profile.bio || "No bio added yet." %></p>

                    <% if (profile.skills && profile.skills.length > 0) { %>
                        <h3 style="font-size: 1rem; margin-bottom: 15px;">Skills</h3>
                        <div style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
                            <% profile.skills.forEach(skill => { %>
                                <span style="background: var(--bg-dark); border: 1px solid var(--border); padding: 5px 15px; border-radius: 20px; font-size: 0.85rem;"><%= skill %></span>
                            <% }) %>
                        </div>
                    <% } %>

                    <% if (profile._id.toString() === user._id.toString()) { %>
                        <button onclick="document.getElementById('edit-profile-modal').style.display='flex'" class="btn-primary" style="margin-top: 30px; display: inline-flex;"><i class="fas fa-edit"></i> Edit Profile</button>
                    <% } else { %>
                        <button onclick="startChat('<%= profile._id %>')" class="btn-primary" style="margin-top: 30px; display: inline-flex;"><i class="fas fa-comment"></i> Send Message</button>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Profile Modal -->
    <% if (profile._id.toString() === user._id.toString()) { %>
    <div id="edit-profile-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 9999; align-items: center; justify-content: center;">
        <div class="panel-card" style="width: 100%; max-width: 500px; max-height: 90vh; overflow-y: auto;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h3 style="font-size: 1.2rem;">Edit Profile</h3>
                <i class="fas fa-times" style="cursor: pointer; color: var(--text-muted);" onclick="document.getElementById('edit-profile-modal').style.display='none'"></i>
            </div>
            
            <form action="/profile/update" method="POST" enctype="multipart/form-data">
                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 0.9rem;">Profile Picture</label>
                    <input type="file" name="avatar" accept="image/*" style="width: 100%; padding: 10px; background: var(--bg-dark); border-radius: 8px; border: 1px solid var(--border); color: white;">
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 0.9rem;">Bio</label>
                    <textarea name="bio" rows="4" style="width: 100%; padding: 10px; background: var(--bg-dark); border-radius: 8px; border: 1px solid var(--border); color: white;"><%= profile.bio %></textarea>
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 0.9rem;">Skills (comma separated)</label>
                    <input type="text" name="skills" value="<%= profile.skills.join(', ') %>" style="width: 100%; padding: 10px; background: var(--bg-dark); border-radius: 8px; border: 1px solid var(--border); color: white;">
                </div>
                <button type="submit" class="btn-primary" style="width: 100%; justify-content: center;">Save Changes</button>
            </form>
        </div>
    </div>
    <% } %>
</main>

<script>
async function startChat(recipientId) {
    try {
        const res = await fetch('/chat/start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ recipientId })
        });
        const data = await res.json();
        if (data.success) {
            window.location.href = `/chat/${data.conversationId}`;
        } else {
            alert(data.message);
        }
    } catch (err) {
        alert('Error starting chat');
    }
}
</script>

<%- include('partials/footer') %>
