<%- include('../partials/header', { title: 'Writer Dashboard | AssignTrust' }) %>
<%- include('../partials/sidebar', { activePage: 'dashboard' }) %>

<main class="main-content">
    <%- include('../partials/topbar') %>

    <div class="page-content">
        <!-- WELCOME BANNER -->
        <div class="welcome-banner" style="background: linear-gradient(135deg, #064e3b 0%, #1a1e35 50%, #0c0e1a 100%);">
            <div class="welcome-text">
                <h1>Ready to earn, <%= user.name %>? 💼</h1>
                <p>Browse new assignments and start sending proposals today.</p>
            </div>
            <a href="/marketplace" class="btn-primary" style="background: linear-gradient(135deg, #10b981, #059669);">
                <i class="fas fa-search"></i> Browse Jobs
            </a>
        </div>

        <!-- STATS GRID -->
        <section class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon purple"><i class="fas fa-paper-plane"></i></div>
                <div class="stat-info">
                    <span class="stat-value"><%= stats.totalProposals %></span>
                    <span class="stat-label">Total Proposals</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue"><i class="fas fa-handshake"></i></div>
                <div class="stat-info">
                    <span class="stat-value"><%= stats.acceptedProposals %></span>
                    <span class="stat-label">Accepted</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon yellow"><i class="fas fa-spinner"></i></div>
                <div class="stat-info">
                    <span class="stat-value"><%= stats.activeProjects %></span>
                    <span class="stat-label">Active Work</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
                <div class="stat-info">
                    <span class="stat-value"><%= stats.completedProjects %></span>
                    <span class="stat-label">Completed</span>
                </div>
            </div>
        </section>

        <div class="dashboard-grid">
            <!-- RECENT PROPOSALS TABLE -->
            <section class="projects-section">
                <div class="section-header">
                    <h2>Recent Proposals</h2>
                    <a href="/my-proposals" class="view-all-link">View All <i class="fas fa-arrow-right"></i></a>
                </div>

                <div class="project-list">
                    <% if (recentProposals && recentProposals.length > 0) { %>
                        <% recentProposals.forEach(prop => { %>
                            <div class="project-card">
                                <div class="proj-thumb <%= prop.status === 'accepted' ? 'green-bg' : (prop.status === 'rejected' ? 'orange-bg' : 'blue-bg') %>">
                                    <i class="fas fa-file-contract"></i>
                                </div>
                                <div class="proj-info">
                                    <h3><%= prop.assignment.title %></h3>
                                    <p><%= prop.assignment.subject %></p>
                                </div>
                                <div class="proj-meta">
                                    <span class="proj-price">₹<%= prop.bidAmount %></span>
                                    <span class="proj-status <%= prop.status === 'accepted' ? 'done-status' : (prop.status === 'rejected' ? 'pending-status' : 'active-status') %>" style="text-transform: capitalize;"><%= prop.status %></span>
                                </div>
                                <div class="proj-progress" style="display:flex; justify-content:flex-end;">
                                    <a href="/assignment/<%= prop.assignment._id %>" class="btn-primary" style="padding: 6px 12px; font-size: 0.8rem;">Details</a>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p style="color: var(--text-muted); text-align: center; padding: 20px;">You haven't sent any proposals yet.</p>
                    <% } %>
                </div>
            </section>

            <!-- RIGHT PANEL -->
            <aside class="right-panel">
                <!-- ACTIVITY FEED -->
                <div class="panel-card">
                    <div class="panel-header">
                        <h3>Recent Activity</h3>
                        <a href="/notifications" class="view-all-link small">See all</a>
                    </div>
                    <div class="activity-list">
                        <% if (notifications && notifications.length > 0) { %>
                            <% notifications.forEach(notif => { %>
                                <div class="activity-item" onclick="window.location.href='<%= notif.link %>'" style="cursor: pointer;">
                                    <div class="activity-icon <%= notif.type.includes('accepted') || notif.type.includes('completed') ? 'green-icon' : 'blue-icon' %>"><i class="fas fa-bell"></i></div>
                                    <div class="activity-content">
                                        <p class="activity-title"><%= notif.message %></p>
                                        <p class="activity-time"><%= new Date(notif.createdAt).toLocaleDateString() %></p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p style="color: var(--text-muted); font-size: 0.85rem;">No recent activity.</p>
                        <% } %>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
