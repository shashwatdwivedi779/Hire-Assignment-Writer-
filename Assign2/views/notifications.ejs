<%- include('partials/header', { title: 'Notifications | AssignTrust' }) %>
<%- include('partials/sidebar', { activePage: 'notifications' }) %>

<main class="main-content">
    <%- include('partials/topbar') %>

    <div class="page-content">
        <div class="welcome-banner" style="padding: 20px 32px; margin-bottom: 20px;">
            <div class="welcome-text">
                <h2>Notifications</h2>
                <p>Stay updated with the latest activity on your account.</p>
            </div>
        </div>

        <div class="panel-card" style="padding: 0; overflow: hidden;">
            <% if (notifications && notifications.length > 0) { %>
                <div style="display: flex; flex-direction: column;">
                    <% notifications.forEach(notif => { %>
                        <a href="<%= notif.link %>" class="notif-item <%= notif.isRead ? 'read' : 'unread' %>" onclick="markRead('<%= notif._id %>')">
                            <% 
                            let iconClass = 'fa-bell';
                            let iconColorClass = 'blue-icon';
                            if (notif.type.includes('proposal')) { iconClass = 'fa-file-contract'; iconColorClass = 'purple-icon'; }
                            if (notif.type.includes('accepted')) { iconClass = 'fa-handshake'; iconColorClass = 'green-icon'; }
                            if (notif.type.includes('rejected')) { iconClass = 'fa-times-circle'; iconColorClass = 'orange-icon'; }
                            if (notif.type.includes('message')) { iconClass = 'fa-comment'; iconColorClass = 'blue-icon'; }
                            if (notif.type.includes('completed')) { iconClass = 'fa-check-circle'; iconColorClass = 'green-icon'; }
                            %>
                            <div class="activity-icon <%= iconColorClass %>" style="flex-shrink: 0;"><i class="fas <%= iconClass %>"></i></div>
                            <div style="flex: 1;">
                                <p style="font-size: 0.95rem; margin-bottom: 5px; color: <%= notif.isRead ? 'var(--text-muted)' : 'white' %>; font-weight: <%= notif.isRead ? '400' : '600' %>;"><%= notif.message %></p>
                                <p style="font-size: 0.75rem; color: var(--text-muted);"><%= new Date(notif.createdAt).toLocaleString() %></p>
                            </div>
                            <% if (!notif.isRead) { %>
                                <div style="width: 10px; height: 10px; border-radius: 50%; background: var(--accent); flex-shrink: 0;"></div>
                            <% } %>
                        </a>
                    <% }) %>
                </div>
            <% } else { %>
                <div style="text-align: center; padding: 50px;">
                    <i class="fas fa-bell-slash" style="font-size: 3rem; color: var(--border); margin-bottom: 20px;"></i>
                    <h3>No notifications</h3>
                    <p style="color: var(--text-muted);">You're all caught up!</p>
                </div>
            <% } %>
        </div>
    </div>
</main>

<style>
.notif-item { display: flex; align-items: center; gap: 15px; padding: 20px 25px; border-bottom: 1px solid var(--border); text-decoration: none; transition: background 0.2s; }
.notif-item:hover { background: rgba(255,255,255,0.03); }
.notif-item.unread { background: rgba(108,99,255,0.05); }
.notif-item:last-child { border-bottom: none; }
</style>

<script>
async function markRead(id) {
    // Only send the request if we actually want to mark it before navigation.
    // Navigation will happen because it's an <a> tag.
    try {
        await fetch(`/notifications/${id}/read`, { method: 'POST' });
    } catch(e) {}
}
</script>

<%- include('partials/footer') %>
