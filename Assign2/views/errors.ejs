<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error | AssignTrust</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #0c0e1a;
            color: #f1f5f9;
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .error-container {
            text-align: center;
            padding: 60px 40px;
            max-width: 520px;
        }
        .error-icon {
            font-size: 5rem;
            background: linear-gradient(135deg, #6c63ff, #00d4ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 24px;
        }
        h1 {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 12px;
            color: #fff;
        }
        p {
            font-size: 1rem;
            color: #8892a4;
            margin-bottom: 36px;
            line-height: 1.6;
        }
        .btn-home {
            display: inline-block;
            padding: 12px 28px;
            background: linear-gradient(135deg, #6c63ff, #00d4ff);
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: opacity 0.2s;
        }
        .btn-home:hover { opacity: 0.85; }
        .btn-back {
            display: inline-block;
            margin-left: 12px;
            padding: 12px 24px;
            background: rgba(255,255,255,0.07);
            color: #ccc;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 500;
            font-size: 0.95rem;
            border: 1px solid rgba(255,255,255,0.12);
            transition: background 0.2s;
        }
        .btn-back:hover { background: rgba(255,255,255,0.12); }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-icon"><i class="fas fa-triangle-exclamation"></i></div>
        <h1>Oops! Something went wrong.</h1>
        <p><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred. Please try again.' %></p>
        <a href="/dashboard" class="btn-home"><i class="fas fa-house"></i> Dashboard</a>
        <a href="javascript:history.back()" class="btn-back"><i class="fas fa-arrow-left"></i> Go Back</a>
    </div>
</body>
</html>
