        <!-- END OF MAIN CONTENT -->
    </div> <!-- end app-container -->

    <!-- Socket.IO and Notification Logic -->
    <script>
        const socket = io();

        // Listen for real-time notifications
        socket.on('notification', (data) => {
            console.log('New notification:', data);
            
            // Increment unread count badge in topbar
            const notifBadge = document.getElementById('topbar-notif-badge');
            if (notifBadge) {
                let count = parseInt(notifBadge.innerText || '0') + 1;
                notifBadge.innerText = count;
                notifBadge.style.display = 'flex';
            }

            // Create a toast notification
            showToast(data.message, data.link);
        });

        // Listen for new messages
        socket.on('new_message', (data) => {
            console.log('New message:', data);
            // Increment unread message badge
            const msgBadge = document.getElementById('topbar-msg-badge');
            if (msgBadge) {
                let count = parseInt(msgBadge.innerText || '0') + 1;
                msgBadge.innerText = count;
                msgBadge.style.display = 'flex';
            }
        });

        function showToast(message, link) {
            // Simple toast implementation
            const toast = document.createElement('div');
            toast.className = 'notif-toast';
            toast.innerHTML = `
                <div class="toast-content">
                    <i class="fas fa-bell"></i>
                    <span>${message}</span>
                </div>
            `;
            if (link) {
                toast.onclick = () => window.location.href = link;
                toast.style.cursor = 'pointer';
            }
            
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.classList.add('show');
            }, 100);

            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }

        // Sidebar toggle logic for mobile
        const menuToggle = document.getElementById('menuToggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        
        if (menuToggle && sidebar && overlay) {
            menuToggle.addEventListener('click', () => {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('active');
            });
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('active');
            });
        }
    </script>

    <style>
        .notif-toast {
            position: fixed;
            bottom: 20px;
            right: -300px;
            background: linear-gradient(135deg, #6c63ff, #00d4ff);
            color: white;
            padding: 15px 20px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(108, 99, 255, 0.4);
            transition: right 0.3s ease;
            z-index: 9999;
            max-width: 300px;
            display: flex;
            align-items: center;
        }
        .notif-toast.show {
            right: 20px;
        }
        .toast-content {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.9rem;
            font-weight: 500;
        }
    </style>

    <%- typeof extraJs !== 'undefined' ? extraJs : '' %>
</body>
</html>
