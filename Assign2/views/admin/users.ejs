<%- include('../partials/header', { title: 'Manage Users | Admin' }) %>
<%- include('../partials/sidebar', { activePage: 'users' }) %>

<main class="main-content">
    <%- include('../partials/topbar') %>

    <div class="page-content">
        <div class="welcome-banner" style="padding: 20px 32px; margin-bottom: 20px;">
            <div class="welcome-text">
                <h2>User Management</h2>
                <p>View, filter, and remove users from the platform.</p>
            </div>
        </div>

        <div class="panel-card" style="margin-bottom: 20px; padding: 15px 20px;">
            <form action="/admin/users" method="GET" style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 200px;">
                    <label style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 5px; display: block;">Search Name/Email</label>
                    <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search..." style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-card2); border: 1px solid var(--border); color: white;">
                </div>
                <div style="flex: 1; min-width: 150px;">
                    <label style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 5px; display: block;">Role</label>
                    <select name="role" style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-card2); border: 1px solid var(--border); color: white;">
                        <option value="">All Roles</option>
                        <option value="client" <%= filters.role === 'client' ? 'selected' : '' %>>Client</option>
                        <option value="writer" <%= filters.role === 'writer' ? 'selected' : '' %>>Writer</option>
                        <option value="admin" <%= filters.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                </div>
                <div style="flex: 1; min-width: 150px;">
                    <label style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 5px; display: block;">College</label>
                    <select name="college" style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-card2); border: 1px solid var(--border); color: white;">
                        <option value="">All Colleges</option>
                        <option value="REC Rewa" <%= filters.college === 'REC Rewa' ? 'selected' : '' %>>REC Rewa</option>
                        <option value="IGEC Sagar" <%= filters.college === 'IGEC Sagar' ? 'selected' : '' %>>IGEC Sagar</option>
                    </select>
                </div>
                <button type="submit" class="btn-primary" style="padding: 10px 20px;">Filter</button>
            </form>
        </div>

        <div class="panel-card" style="padding: 0; overflow: hidden;">
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.02); text-align: left;">
                            <th style="padding: 15px;">User</th>
                            <th style="padding: 15px;">Email</th>
                            <th style="padding: 15px;">Role</th>
                            <th style="padding: 15px;">College</th>
                            <th style="padding: 15px;">Joined</th>
                            <th style="padding: 15px; text-align: center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (users && users.length > 0) { %>
                            <% users.forEach(u => { %>
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                    <td style="padding: 15px;">
                                        <div style="display: flex; align-items: center; gap: 10px;">
                                            <img src="<%= u.avatar || 'https://i.pravatar.cc/150?img=12' %>" alt="" style="width: 30px; height: 30px; border-radius: 50%;">
                                            <span style="font-weight: 600;"><%= u.name %></span>
                                        </div>
                                    </td>
                                    <td style="padding: 15px; color: var(--text-muted);"><%= u.email %></td>
                                    <td style="padding: 15px; text-transform: capitalize;"><%= u.role %></td>
                                    <td style="padding: 15px;"><%= u.college %></td>
                                    <td style="padding: 15px; color: var(--text-muted);"><%= new Date(u.createdAt).toLocaleDateString() %></td>
                                    <td style="padding: 15px; text-align: center;">
                                        <% if (u.role !== 'admin' || u._id.toString() !== user._id.toString()) { %>
                                            <button onclick="deleteUser('<%= u._id %>')" class="icon-btn" style="color: #ef4444; background: rgba(239,68,68,0.1); border: none;" title="Delete User"><i class="fas fa-trash"></i></button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="6" style="padding: 30px; text-align: center; color: var(--text-muted);">No users found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<script>
async function deleteUser(id) {
    if (!confirm('Are you sure you want to delete this user? This action cannot be undone.')) return;
    try {
        const res = await fetch(`/admin/users/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.message);
        }
    } catch(e) {
        alert('Error deleting user');
    }
}
</script>

<%- include('../partials/footer') %>
