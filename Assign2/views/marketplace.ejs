<%- include('partials/header', { title: 'Marketplace | AssignTrust' }) %>
<%- include('partials/sidebar', { activePage: 'marketplace' }) %>

<main class="main-content">
    <%- include('partials/topbar') %>

    <div class="page-content">
        <div class="welcome-banner" style="padding: 20px 32px; margin-bottom: 20px;">
            <div class="welcome-text">
                <h2>Browse Assignments</h2>
                <p>Find the perfect project that matches your skills.</p>
            </div>
        </div>

        <!-- FILTERS -->
        <div class="panel-card" style="margin-bottom: 20px; padding: 15px 20px;">
            <form action="/marketplace" method="GET" style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 200px;">
                    <label style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 5px; display: block;">Search</label>
                    <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Keywords..." style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-card2); border: 1px solid var(--border); color: white;">
                </div>
                <div style="flex: 1; min-width: 150px;">
                    <label style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 5px; display: block;">College</label>
                    <select name="college" style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-card2); border: 1px solid var(--border); color: white;">
                        <option value="">All Colleges</option>
                        <option value="REC Rewa" <%= filters.college === 'REC Rewa' ? 'selected' : '' %>>REC Rewa</option>
                        <option value="IGEC Sagar" <%= filters.college === 'IGEC Sagar' ? 'selected' : '' %>>IGEC Sagar</option>
                    </select>
                </div>
                <div style="flex: 1; min-width: 120px;">
                    <label style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 5px; display: block;">Sort By</label>
                    <select name="sort" style="width: 100%; padding: 10px; border-radius: 8px; background: var(--bg-card2); border: 1px solid var(--border); color: white;">
                        <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest</option>
                        <option value="deadline" <%= filters.sort === 'deadline' ? 'selected' : '' %>>Ending Soon</option>
                        <option value="budget" <%= filters.sort === 'budget' ? 'selected' : '' %>>Highest Budget</option>
                    </select>
                </div>
                <button type="submit" class="btn-primary" style="padding: 10px 20px; border: none; cursor: pointer;">Apply Filters</button>
            </form>
        </div>

        <!-- ASSIGNMENTS LIST -->
        <div class="project-list">
            <% if (assignments && assignments.length > 0) { %>
                <% assignments.forEach(assignment => { %>
                    <div class="project-card" style="grid-template-columns: 60px 1fr auto auto; align-items: start; padding: 20px;">
                        <img src="<%= assignment.student.avatar || 'https://i.pravatar.cc/150?img=11' %>" alt="Client" style="width: 50px; height: 50px; border-radius: 50%;">
                        <div class="proj-info">
                            <h3 style="font-size: 1.1rem; margin-bottom: 5px;">
                                <a href="/assignment/<%= assignment._id %>" style="color: white; text-decoration: none;"><%= assignment.title %></a>
                            </h3>
                            <p style="color: var(--accent2); font-size: 0.85rem; margin-bottom: 10px;"><%= assignment.college %> • <%= assignment.student.name %></p>
                            <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 15px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= assignment.description %></p>
                            
                            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                                <span style="background: rgba(255,255,255,0.05); padding: 4px 10px; border-radius: 6px; font-size: 0.75rem;"><i class="fas fa-book"></i> <%= assignment.subject %></span>
                                <span style="background: rgba(255,255,255,0.05); padding: 4px 10px; border-radius: 6px; font-size: 0.75rem;"><i class="fas fa-clock"></i> Deadline: <%= new Date(assignment.deadline).toLocaleDateString() %></span>
                                <% if (assignment.urgency === 'urgent' || assignment.urgency === 'critical') { %>
                                    <span style="background: rgba(239,68,68,0.15); color: #ef4444; padding: 4px 10px; border-radius: 6px; font-size: 0.75rem;"><i class="fas fa-fire"></i> <%= assignment.urgency %></span>
                                <% } %>
                            </div>
                        </div>
                        <div class="proj-meta" style="align-items: center; justify-content: center; padding: 0 20px; border-left: 1px solid var(--border); border-right: 1px solid var(--border);">
                            <span style="font-size: 1.2rem; font-weight: 800; color: var(--green);">₹<%= assignment.budget.min %> - ₹<%= assignment.budget.max %></span>
                            <span style="font-size: 0.8rem; color: var(--text-muted); margin-top: 5px;">Est. Budget</span>
                        </div>
                        <div class="proj-progress" style="display: flex; flex-direction: column; gap: 10px; justify-content: center; padding-left: 20px;">
                            <a href="/assignment/<%= assignment._id %>" class="btn-primary" style="text-align: center;">View Details</a>
                            <% if (assignment.alreadyProposed) { %>
                                <span style="text-align: center; font-size: 0.8rem; color: var(--green);"><i class="fas fa-check-circle"></i> Proposed</span>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="panel-card" style="text-align: center; padding: 50px;">
                    <i class="fas fa-search" style="font-size: 3rem; color: var(--border); margin-bottom: 20px;"></i>
                    <h3>No assignments found</h3>
                    <p style="color: var(--text-muted);">Try adjusting your filters or check back later.</p>
                </div>
            <% } %>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
