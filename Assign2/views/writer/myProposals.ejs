<%- include('../partials/header', { title: 'My Proposals | AssignTrust' }) %>
<%- include('../partials/sidebar', { activePage: 'proposals' }) %>

<main class="main-content">
    <%- include('../partials/topbar') %>

    <div class="page-content">
        <div class="welcome-banner" style="padding: 20px 32px; margin-bottom: 20px; background: linear-gradient(135deg, #0f172a, #1e1b4b);">
            <div class="welcome-text">
                <h2>My Proposals</h2>
                <p>Track the status of all your submitted proposals.</p>
            </div>
        </div>

        <div class="panel-card" style="margin-bottom: 20px; padding: 0; overflow: hidden;">
            <div style="display: flex; border-bottom: 1px solid var(--border);">
                <a href="/my-proposals" style="padding: 15px 25px; text-decoration: none; color: <%= activeStatus === 'all' ? 'var(--accent)' : 'var(--text-muted)' %>; border-bottom: 2px solid <%= activeStatus === 'all' ? 'var(--accent)' : 'transparent' %>; font-weight: 600;">All</a>
                <a href="/my-proposals?status=pending" style="padding: 15px 25px; text-decoration: none; color: <%= activeStatus === 'pending' ? 'var(--accent)' : 'var(--text-muted)' %>; border-bottom: 2px solid <%= activeStatus === 'pending' ? 'var(--accent)' : 'transparent' %>; font-weight: 600;">Pending</a>
                <a href="/my-proposals?status=accepted" style="padding: 15px 25px; text-decoration: none; color: <%= activeStatus === 'accepted' ? 'var(--accent)' : 'var(--text-muted)' %>; border-bottom: 2px solid <%= activeStatus === 'accepted' ? 'var(--accent)' : 'transparent' %>; font-weight: 600;">Accepted</a>
                <a href="/my-proposals?status=rejected" style="padding: 15px 25px; text-decoration: none; color: <%= activeStatus === 'rejected' ? 'var(--accent)' : 'var(--text-muted)' %>; border-bottom: 2px solid <%= activeStatus === 'rejected' ? 'var(--accent)' : 'transparent' %>; font-weight: 600;">Rejected</a>
            </div>
        </div>

        <div class="project-list">
            <% if (proposals && proposals.length > 0) { %>
                <% proposals.forEach(prop => { %>
                    <div class="project-card">
                        <div class="proj-thumb <%= prop.status === 'accepted' ? 'green-bg' : (prop.status === 'rejected' ? 'orange-bg' : 'blue-bg') %>">
                            <i class="fas fa-file-contract"></i>
                        </div>
                        <div class="proj-info">
                            <h3><a href="/assignment/<%= prop.assignment._id %>" style="color: white; text-decoration: none;"><%= prop.assignment.title %></a></h3>
                            <p><%= prop.assignment.subject %> • Proposed ₹<%= prop.bidAmount %> in <%= prop.deliveryTime %>hrs</p>
                        </div>
                        <div class="proj-meta">
                            <% 
                            let statusClass = 'pending-status';
                            if (prop.status === 'accepted') statusClass = 'done-status';
                            if (prop.status === 'rejected' || prop.status === 'withdrawn') statusClass = 'pending-status'; // should be red/grey
                            %>
                            <span class="proj-status <%= statusClass %>" style="text-transform: capitalize;"><%= prop.status %></span>
                            <span style="font-size: 0.8rem; color: var(--text-muted);"><%= new Date(prop.createdAt).toLocaleDateString() %></span>
                        </div>
                        <div class="proj-progress" style="display:flex; justify-content:flex-end; gap: 10px;">
                            <a href="/assignment/<%= prop.assignment._id %>" class="btn-primary" style="padding: 6px 12px; font-size: 0.8rem; background: var(--bg-card2); border: 1px solid var(--border); color: white;">View Details</a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="panel-card" style="text-align: center; padding: 50px;">
                    <i class="fas fa-paper-plane" style="font-size: 3rem; color: var(--border); margin-bottom: 20px;"></i>
                    <h3>No proposals found</h3>
                    <p style="color: var(--text-muted);">You haven't submitted any proposals matching this status.</p>
                </div>
            <% } %>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
