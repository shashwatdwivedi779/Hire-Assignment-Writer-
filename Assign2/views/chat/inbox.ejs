<%- include('../partials/header', { title: 'Inbox | AssignTrust' }) %>
<%- include('../partials/sidebar', { activePage: 'chat' }) %>

<main class="main-content">
    <%- include('../partials/topbar') %>

    <div class="page-content" style="height: calc(100vh - 80px); display: flex; flex-direction: column; overflow: hidden; padding-bottom: 0;">
        <div class="panel-card" style="flex: 1; display: flex; padding: 0; overflow: hidden; border-radius: 12px 12px 0 0;">
            
            <!-- INBOX SIDEBAR -->
            <div style="width: 320px; border-right: 1px solid var(--border); display: flex; flex-direction: column; background: var(--bg-card);">
                <div style="padding: 20px; border-bottom: 1px solid var(--border);">
                    <h2 style="font-size: 1.2rem; margin-bottom: 15px;">Messages</h2>
                    <div style="position: relative;">
                        <i class="fas fa-search" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                        <input type="text" placeholder="Search conversations..." style="width: 100%; padding: 10px 10px 10px 40px; border-radius: 8px; background: var(--bg-dark); border: 1px solid var(--border); color: white;">
                    </div>
                </div>

                <div style="flex: 1; overflow-y: auto;" class="custom-scrollbar">
                    <% if (conversations && conversations.length > 0) { %>
                        <% conversations.forEach(conv => { %>
                            <a href="/chat/<%= conv._id %>" style="display: block; padding: 15px 20px; border-bottom: 1px solid rgba(255,255,255,0.03); text-decoration: none; color: inherit; transition: background 0.2s;" class="conv-item hover-bg">
                                <div style="display: flex; gap: 15px; align-items: center;">
                                    <div style="position: relative;">
                                        <img src="<%= conv.other.avatar || 'https://i.pravatar.cc/150?img=12' %>" alt="User" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover;">
                                        <% if (conv.other.isOnline) { %>
                                            <div style="position: absolute; bottom: 2px; right: 2px; width: 10px; height: 10px; background: #10b981; border-radius: 50%; border: 2px solid var(--bg-card);"></div>
                                        <% } %>
                                    </div>
                                    <div style="flex: 1; overflow: hidden;">
                                        <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 3px;">
                                            <h4 style="font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= conv.other.name %></h4>
                                            <span style="font-size: 0.7rem; color: var(--text-muted);"><%= new Date(conv.lastMessageAt).toLocaleDateString() %></span>
                                        </div>
                                        <div style="display: flex; justify-content: space-between; align-items: center;">
                                            <p style="font-size: 0.85rem; color: <%= conv.unread > 0 ? 'white' : 'var(--text-muted)' %>; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 0; font-weight: <%= conv.unread > 0 ? '600' : '400' %>;">
                                                <%= conv.lastMessage || 'Start a conversation...' %>
                                            </p>
                                            <% if (conv.unread > 0) { %>
                                                <span style="background: var(--accent); color: white; border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: bold; flex-shrink: 0;"><%= conv.unread %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <div style="text-align: center; padding: 40px 20px; color: var(--text-muted);">
                            <i class="fas fa-comments" style="font-size: 2.5rem; margin-bottom: 15px; opacity: 0.5;"></i>
                            <p style="font-size: 0.9rem;">No conversations yet.</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- EMPTY CHAT AREA -->
            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--bg-dark); color: var(--text-muted);">
                <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--bg-card); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
                    <i class="fas fa-paper-plane" style="font-size: 2rem; color: var(--accent);"></i>
                </div>
                <h3 style="font-size: 1.2rem; color: white; margin-bottom: 10px;">Your Messages</h3>
                <p>Select a conversation from the sidebar to start chatting.</p>
            </div>

        </div>
    </div>
</main>

<style>
.hover-bg:hover { background: rgba(255,255,255,0.03); }
</style>

<%- include('../partials/footer') %>
